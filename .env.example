# Add Object Framework Environment Variables
# Copy this file to .env and fill in your API keys

# Aliyun DashScope API Key (for wanx2.1-imageedit inpainting; used by --model wanx)
# Get one at https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Stability AI API Key
STABILITY_API_KEY=your_stability_api_key_here

# Replicate API Token
REPLICATE_API_TOKEN=your_replicate_token_here

# OpenAI API Key (for GPT-4 Vision analysis)
OPENAI_API_KEY=your_openai_api_key_here
